{
  "compilerOptions": {
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "isolatedModules": true,
    "importsNotUsedAsValues": "error",
    "module": "ES2020",
    "moduleResolution": "Node",
    "target": "ES2020",
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
